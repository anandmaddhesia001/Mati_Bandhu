# Flask
FLASK_APP=app.py
FLASK_ENV=development

# optional: override run port and/or internal values
PORT=7000
DEBUG=True

# secret key for Flask (session/csrf if you add in future)
SECRET_KEY=your_very_secret_key_here

# model file paths (optional, if you later configure dynamic paths)
DISEASE_MODEL_PATH=models/plant_disease_model.pth
CROP_MODEL_PATH=models/crop.pkl
FERT_CAT_PATH=models/categorical_model.joblib
FERT_NUM_PATH=models/numerical_model.joblib
FERT_PREP_PATH=models/preprocessor.joblib